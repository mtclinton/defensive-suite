# /etc/agentd/agentd.env  (install 0600)
#
# M3 manual-response configuration. SAFE BY DEFAULT: with AGENT_ENABLE_RESPONSE
# unset, agentd serves the response socket in DRY-RUN and performs NO destructive
# action. Review deploy/RESPONSE.md before going live; validate in a VM first.

# Bearer token the collector must present as `Authorization: Bearer <token>`.
# Generate one with:  openssl rand -hex 32
AGENT_RESPONSE_TOKEN=replace-with-a-long-random-token

# Unix socket agentd serves POST /respond on (root, 0600). Default /run/agentd.sock.
# AGENT_RESPONSE_SOCKET=/run/agentd.sock

# Master switch. UNSET / 0 / false → DRY-RUN (returns "what it WOULD do", audited,
# executor never called). Set to 1 ONLY after VM validation to perform real actions.
# AGENT_ENABLE_RESPONSE=0

# Management/keep-up interfaces that `isolate` must never drop (loopback is always
# kept). Comma-separated, e.g. your SSH/Tailscale iface.
# AGENT_MGMT_IFACES=tailscale0,eth0

# Where `quarantine` moves files (the audit log lives one dir up).
# AGENT_QUARANTINE_DIR=/var/lib/agentd/quarantine

# --- BRAKES on the weaponizable primitive (safe defaults; override if needed) ---

# KILL-SWITCH: a file path that, WHEN IT EXISTS, instantly disarms ALL response
# (live AND dry-run) without restarting agentd — every request is refused and
# audited. `touch` it to disarm, `rm` it to re-arm. Default /run/agentd/response.disabled
# (tmpfs, alongside the socket; clears on reboot). Override only to relocate it.
# AGENT_RESPONSE_KILLSWITCH=/run/agentd/response.disabled

# RATE LIMIT on LIVE executions (dry-run is free): "N/Wduration" (or just "N" to
# keep the default 60s window; "0" disables). A hijacked surface cannot become a
# rapid mass-kill/mass-isolate DoS — the (N+1)th action in the window is refused
# and audited. Default 10/60s.
# AGENT_RESPONSE_RATE=10/60s

# --- existing M1 settings (observe pipeline) also live here ---
# AGENT_COLLECTOR_URL=http://127.0.0.1:8787/ingest
# AGENT_COLLECTOR_AUTH=Bearer <the COLLECTOR_TOKEN value>
