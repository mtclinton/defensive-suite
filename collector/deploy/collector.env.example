# /etc/collector/collector.env  (install 0600)
#
# Bearer token the tools must present as `Authorization: Bearer <token>`.
# Generate one with:  openssl rand -hex 32
COLLECTOR_TOKEN=replace-with-a-long-random-token

# Optional overrides (flags take precedence over these):
# COLLECTOR_ADDR=100.64.0.5:8787      # bind a private/Tailscale interface for fleet ingest
# COLLECTOR_DATA_DIR=/var/lib/collector
# COLLECTOR_RETENTION_DAYS=30
# COLLECTOR_MAX_REPORTS=5000

# --- M3 manual response (optional) ---
# Enables POST /api/respond, which forwards the operator's request to the
# root-owned agentd socket and audits it. BOTH must be set or the endpoint is
# absent / fails closed. The token must match agentd's AGENT_RESPONSE_TOKEN.
# COLLECTOR_AGENT_SOCKET=/run/agentd.sock
# COLLECTOR_RESPONSE_TOKEN=replace-with-the-same-value-as-AGENT_RESPONSE_TOKEN
