{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "defensive-suite console",
  "version": "0.1.0",
  "identifier": "club.cybercrime.dsuite.console",
  "build": {
    "frontendDist": "../../dashboard"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "defensive-suite",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://127.0.0.1:8787 http://localhost:8787"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "defensive-suite endpoint console",
    "createUpdaterArtifacts": false
  },
  "plugins": {
    "notification": {},
    "updater": {
      "endpoints": [
        "https://github.com/mtclinton/defensive-suite/releases/latest/download/latest.json"
      ],
      "pubkey": "PLACEHOLDER_REPLACE_VIA_make_console-keygen__UPDATER_IS_INERT_UNTIL_SET"
    }
  }
}
