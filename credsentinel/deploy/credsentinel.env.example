# credsentinel environment — SECRETS AND TOKEN DATA ONLY (mode 0600, env-only).
# Nothing here belongs in config.json; these never get serialized into a report.
#
#   install -m 0600 deploy/credsentinel.env.example /etc/credsentinel/credsentinel.env
#   $EDITOR /etc/credsentinel/credsentinel.env

# Authorization header sent with the webhook POST.
CREDSENTINEL_WEBHOOK_AUTH=Bearer REPLACE_WITH_TOKEN

# Self-hosted Canarytoken DNS hostname woven into the decoy .env. A process that
# resolves or exfiltrates this host trips the token on your own infra (see
# deploy/README.md — self-host Thinkst Canarytokens behind Tailscale).
CREDSENTINEL_CANARY_HOST=REPLACE.canary.your-homelab.internal

# Optional overrides (otherwise from config.json / defaults):
# CREDSENTINEL_WEBHOOK_URL=https://collector.example.internal/ingest/credsentinel
# CREDSENTINEL_SCAN_ROOTS=/home/dev/src,/home/dev/work,/home/dev
# CREDSENTINEL_HOME=/home/dev
# CREDSENTINEL_HONEYTOKEN_DIR=/home/dev
# CREDSENTINEL_MANIFEST=/home/dev/.config/credsentinel/honeytokens.json
